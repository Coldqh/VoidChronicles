{
  "name": "void-chronicles",
  "private": true,
  "version": "0.9.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "validate:source": "node scripts/validate-source-index.mjs",
    "prebuild": "npm run validate:source && npm run validate:brand",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm test && npm run build",
    "validate:brand": "node scripts/validate-brand-assets.mjs"
  },
  "dependencies": {
    "dexie": "4.0.8",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "6.0.3",
    "fake-indexeddb": "6.2.4",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22.12.0 <23",
    "npm": ">=10 <12"
  },
  "packageManager": "npm@10.9.2"
}
